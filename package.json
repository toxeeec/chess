{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "chess",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"build": "vite build",
		"build:game-server": "cargo build --manifest-path game-server/Cargo.toml --target wasm32-unknown-unknown && wasm-bindgen game-server/target/wasm32-unknown-unknown/debug/game_server.wasm --target module --typescript --out-dir game-server/build --experimental-reset-state-function && node scripts/patchGameServerWasmImport.mjs",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"deploy": "pnpm run build && wrangler deploy",
		"dev": "portless run vite dev",
		"fmt": "oxfmt; cargo fmt --manifest-path game-server/Cargo.toml",
		"generate-types": "wrangler types",
		"lint:rs": "cargo clippy --manifest-path game-server/Cargo.toml",
		"lint:ts": "oxlint",
		"lint": "status=0; pnpm run lint:ts || status=$?; pnpm run lint:rs || status=$?; exit $status",
		"prepare": "prek install --quiet --prepare-hooks",
		"preview": "vite preview",
		"skills:install": "skills experimental_install",
		"test:rs": "cargo test --manifest-path game-server/Cargo.toml",
		"test:ts": "vitest run",
		"test": "status=0; pnpm run test:ts || status=$?; pnpm run test:rs || status=$?; exit $status"
	},
	"dependencies": {
		"@dnd-kit/abstract": "^0.4.0",
		"@dnd-kit/dom": "^0.4.0",
		"@dnd-kit/react": "^0.4.0",
		"@tanstack/react-router": "1.170.11",
		"@tanstack/react-start": "1.168.20",
		"drizzle-orm": "1.0.0-rc.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.40.0",
		"@cloudflare/vitest-pool-workers": "^0.16.13",
		"@j178/prek": "^0.4.4",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/devtools-vite": "0.7.0",
		"@tanstack/react-devtools": "0.10.5",
		"@tanstack/react-router-devtools": "1.167.0",
		"@tanstack/router-plugin": "^1.168.14",
		"@tanstack/start-storage-context": "^1.167.11",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "1.0.0-rc.3",
		"oxfmt": "^0.53.0",
		"oxlint": "^1.68.0",
		"oxlint-tsgolint": "^0.23.0",
		"portless": "^0.13.1",
		"skills": "^1.5.10",
		"tailwindcss": "^4.3.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.98.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.0.0",
			"onFail": "error"
		}
	}
}
